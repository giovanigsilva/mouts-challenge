{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Application": {
    "Name": "DeveloperStore Sales API",
    "Version": "1.0.0",
    "EnvironmentName": "Base"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "DeveloperStore",
    "Audience": "DeveloperStore",
    "ExpirationMinutes": 480
  },
  "Swagger": {
    "Enabled": false,
    "Title": "DeveloperStore Sales API",
    "Version": "v1",
    "Description": "API de vendas do DeveloperStore"
  },
  "Security": {
    "AllowedOrigins": [],
    "EnableHsts": false,
    "EnableHttpsRedirection": true,
    "EnableSecurityHeaders": true,
    "EnableRateLimiting": false
  },
  "Features": {
    "EnableDetailedErrors": false
  },
  "Observability": {
    "ServiceName": "developerstore-sales-api",
    "EnableDatadog": true,
    "EnableSeqFallback": true,
    "EnableSerilogSelfLog": false,
    "LogRequestBody": false,
    "LogResponseBody": false,
    "MaskSensitiveData": true
  },
  "Seq": {
    "Enabled": true,
    "Url": "http://seq:5341",
    "ApiKey": ""
  },
  "Datadog": {
    "Enabled": true,
    "Service": "developerstore-sales-api",
    "Environment": "development",
    "Version": "1.0.0"
  },
  "Logging": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
