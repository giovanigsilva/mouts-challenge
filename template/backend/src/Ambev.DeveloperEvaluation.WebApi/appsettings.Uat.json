{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Application": {
    "EnvironmentName": "Uat"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "DeveloperStore.Uat",
    "Audience": "DeveloperStore.Api",
    "ExpirationMinutes": 480
  },
  "Vault": {
    "Enabled": false,
    "Address": "",
    "Token": "",
    "Mount": "secret",
    "Path": "",
    "TimeoutSeconds": 5,
    "FailFastInProduction": true
  },
  "Swagger": {
    "Enabled": true
  },
  "Security": {
    "AllowedOrigins": [],
    "EnableHsts": false,
    "EnableHttpsRedirection": true,
    "EnableSecurityHeaders": true,
    "EnableRateLimiting": true
  },
  "Features": {
    "EnableDetailedErrors": false
  },
  "Observability": {
    "EnableSerilogSelfLog": false
  },
  "Seq": {
    "Enabled": true,
    "Url": "http://seq:5341"
  },
  "Datadog": {
    "Environment": "uat"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
