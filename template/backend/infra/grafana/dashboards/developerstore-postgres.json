{
  "uid": "developerstore-postgres",
  "title": "DeveloperStore PostgreSQL",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "PostgreSQL up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "pg_up", "legendFormat": "up" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Conexoes por estado",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (state) (pg_stat_activity_count)", "legendFormat": "{{state}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Transacoes com commit",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "commit/s" }
      ]
    }
  ]
}
