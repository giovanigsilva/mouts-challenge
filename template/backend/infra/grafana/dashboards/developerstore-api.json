{
  "uid": "developerstore-api",
  "title": "DeveloperStore API",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Requests por minuto",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_server_request_duration_seconds_count[1m])) * 60", "legendFormat": "rpm" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Status codes",
      "gridPos": { "x": 6, "y": 0, "w": 10, "h": 8 },
      "targets": [
        { "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count[5m]))", "legendFormat": "{{http_response_status_code}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latencia media",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_server_request_duration_seconds_sum[5m])) / sum(rate(http_server_request_duration_seconds_count[5m]))", "legendFormat": "segundos" }
      ]
    }
  ]
}
