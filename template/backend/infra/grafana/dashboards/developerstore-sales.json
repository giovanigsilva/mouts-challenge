{
  "uid": "developerstore-sales",
  "title": "DeveloperStore Sales",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Vendas criadas",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(developerstore_sales_created_total)", "legendFormat": "criadas" }
      ]
    },
    {
      "type": "stat",
      "title": "Vendas atualizadas",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(developerstore_sales_modified_total)", "legendFormat": "atualizadas" }
      ]
    },
    {
      "type": "stat",
      "title": "Vendas canceladas",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(developerstore_sales_cancelled_total)", "legendFormat": "canceladas" }
      ]
    },
    {
      "type": "stat",
      "title": "Itens cancelados",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(developerstore_sales_item_cancelled_total)", "legendFormat": "itens" }
      ]
    }
  ]
}
